# =====================================================
# earth2guide — 환경변수 키 가이드 (실값 X)
# =====================================================
# 실제 값은 각 폴더의 .env.local에 들어있음:
#   - web/.env.local       (빌드/런타임 키, public 안전)
#   - pipeline/.env.local  (서비스 키, 절대 git에 X)
# =====================================================

# ---------- Supabase ----------
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 아래는 pipeline/.env.local 에만 (Admin 작업용)
SUPABASE_SERVICE_KEY=eyJ...

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=xxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
R2_BUCKET_NAME=e2korea
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxxxx.r2.dev

# ---------- 사이트 (web/.env.local) ----------
NEXT_PUBLIC_SITE_URL=https://earth2guide.com
NEXT_PUBLIC_DEFAULT_LOCALE=ko

# ---------- Gemini (pipeline/.env.local) ----------
GEMINI_API_KEY=AIza...

# ---------- Phase 3 (아직 미사용) ----------
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_SECRET=

# =====================================================
# 어떤 키가 어디에 가는지
# =====================================================
# web/.env.local     →  NEXT_PUBLIC_*, R2_BUCKET_NAME
# pipeline/.env.local →  위 + SUPABASE_SERVICE_KEY + GEMINI_API_KEY
#                        + R2 secret keys (이미지 업로드용)
# =====================================================
