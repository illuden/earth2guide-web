# =====================================================
# earth2guide — 모노레포 .gitignore
# =====================================================
# 원칙:
#   - GitHub에 올라가는 건 web/ 안의 코드만
#   - pipeline/, data/는 Vercel 빌드와 무관 → git scope 안 들어감
#   - 대용량/민감 파일 차단
# =====================================================

# ---------- 환경변수 (절대 git에 올리지 않음) ----------
.env
.env.local
.env.*.local
.env.production
.env.development

# ---------- 대용량 데이터 (R2에 이미 업로드된 것) ----------
data/
earth2_scraped/

# ---------- pipeline 폴더 전체 (로컬 작업용) ----------
pipeline/

# ---------- Discord 아카이브 (pipeline 안이지만 명시) ----------
**/공지사항_국문/
**/공지사항_영문/
**/공식_홍보자료/
**/메인서버_업데이트/
**/어스2_관련소식/
**/업데이트_국문/
**/업데이트_영문/
**/개발자_문답/
**/files/

# ---------- 미디어 / 대용량 파일 ----------
*.mp4
*.mov
*.avi
*.zip
*.rar
*.7z
*.iso

# 이미지: web/public 안의 것만 허용
*.psd
*.ai
*.sketch

# ---------- 빌드 산출물 ----------
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo

# ---------- 캐시 ----------
.cache/
.parcel-cache/
.turbo/
.eslintcache

# ---------- 로그 ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- 체크포인트 (스크립트 진행 상태) ----------
*_checkpoint.json
checkpoint.json
pipeline_checkpoint.json

# ---------- DB 파일 (로컬 SQLite) ----------
*.db
*.sqlite
*.sqlite3

# ---------- IDE / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Vercel ----------
.vercel/

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Python (pipeline 작업용) ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# ---------- 임시 / 사용자 메모 ----------
*.tmp
*.bak
*.swp
TODO.local.md
NOTES.local.md
